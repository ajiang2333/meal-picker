# SQLite database file is resolved relative to apps/api/prisma/schema.prisma.
# On Ubuntu this keeps the production DB inside the deployed project folder:
# /opt/waimai-picker/apps/api/prisma/prod.db
DATABASE_URL="file:./prod.db"
PORT=8787
NODE_ENV=production
# Optional. Set this to your public API origin when using a domain/reverse proxy.
PUBLIC_BASE_URL=""
